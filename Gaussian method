#include <stdio.h> 
#include <stdlib.h>

void change_str(int size, double matrix[size][size], int first_str, int second_str){
    for(int i = 0; i< size; i++){
       double temp = matrix[first_str][i];
       matrix[first_str][i] = matrix[second_str][i];
       matrix[second_str][i] = temp;
    }
    return;
}

void multiply_str_by_number(int size, double matrix[size][size], double num, int num_string){
    for(int i = 0; i <size; i++ ){
        matrix[num_string][i]= matrix[num_string][i] * num;
    }
    return;
}
void multiply_str_by_number_plus_another_str(int size, double matrix[size][size], double num, int target, int source ){
    double temp[size][size];
    for(int i = 0; i < size; i++){
        temp[0][i] = matrix[source][i];
    }
    multiply_str_by_number(size, temp , num , 0);
    for(int i = 0; i <size; i++ ){
        matrix[target][i] +=  temp[0][i];}
    return;
}
double Gaussian_method(int size, double matrix[size][size]){
    double result = 1;
    for(int i = 0; i < size; i++){
        if(matrix[i][i]==0){
            int k = i + 1;
            while(k < size&&matrix[k][i]==0){
                k++;
            }
            if(k == size){
                return 0;
            }
            change_str(size, matrix, i, k ); 
            result*=-1;
            }
        double a = matrix[i][i];
        
        for(int l = i + 1; l< size; l++){
            double point = -(matrix[l][i]/a);
            multiply_str_by_number_plus_another_str(size, matrix, point, l, i );
        }
    }
    for(int i = 0; i < size; i++){
        result *= matrix[i][i];
    }
return result;
}
int main(){
int sizemat;
scanf("%d", &sizemat);
double matrix[sizemat][sizemat];
for(int i = 0; i < sizemat; i++){
    for(int k = 0; k < sizemat; k++){
        scanf("%lf", &matrix[i][k]);
    }
}
printf("%lf", Gaussian_method(sizemat, matrix));





return 0;
}
